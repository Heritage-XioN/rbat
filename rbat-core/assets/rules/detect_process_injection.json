{
  "meta": {
    "name": "Privilege Escalation: Process Injection",
    "description": "Detects suspicious API calls related to remote memory allocation, writing process memory, or remote execution.",
    "mitre_attack": "T1055",
    "severity": "Critical",
    "category": "privilege_escalation",
    "weight": 35,
    "author": "RBAT Security Team",
    "references": [
      "https://attack.mitre.org/techniques/T1055/"
    ],
    "tags": ["process_injection", "injection", "memory"]
  },
  "condition": {
    "or": [
      { "feature": { "api": "VirtualAllocEx" } },
      { "feature": { "api": "WriteProcessMemory" } },
      { "feature": { "api": "CreateRemoteThread" } },
      { "feature": { "api": "NtCreateThreadEx" } }
    ]
  }
}

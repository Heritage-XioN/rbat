{
  "meta": {
    "name": "vss_shadowcopy_deletion",
    "description": "Flags command invocations that delete VSS volume shadow copies to prevent system recovery",
    "mitre_attack": "T1490",
    "severity": "Critical",
    "category": "impact",
    "weight": 90,
    "author": "RBAT Security Team",
    "references": [
      "https://attack.mitre.org/techniques/T1490/"
    ],
    "tags": ["ransomware", "impact", "vss"]
  },
  "condition": {
    "or": [
      {
        "feature": {
          "string": "vssadmin delete shadows"
        }
      },
      {
        "feature": {
          "string": "wmic shadowcopy delete"
        }
      },
      {
        "feature": {
          "string": "bcdedit /set {default} recoveryenabled No"
        }
      }
    ]
  }
}

{
  "rule": {
    "meta": {
      "name": "persistence_api_hooking",
      "description": "Detects API functions commonly used for hooking, detour, or interception techniques",
      "severity": "High",
      "category": "persistence",
      "weight": 25,
      "mitre_attack": "Persistence::Input Capture [T1056]",
      "authors": "RBAT Security Team",
      "tags": ["api_hooking", "detours", "interception"]
    },
    "features": [
      {
        "or": [
          { "api": "SetWindowsHookEx" },
          { "api": "DetourAttach" },
          { "api": "MH_CreateHook" },
          { "api": "frida_agent_main" }
        ]
      }
    ]
  }
}

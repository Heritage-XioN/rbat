# =============================================================================
# RBAT Environment Variables Template
# =============================================================================
# Instructions:
# 1. Copy this file to .env: cp .env.example .env
# 2. Update the values below with your deployment configuration.
# =============================================================================

# Public-facing domain name for routing (e.g., rbat.example.com)
DOMAIN=localhost

# Email address used for Let's Encrypt TLS registration
ACME_EMAIL=admin@example.com

# Minio Object Storage Root User Credentials
MINIO_ROOT_USER=admin_user
MINIO_ROOT_PASSWORD=super_secure_password_change_me

# =============================================================================
# RBAT Environment Variables Template
# =============================================================================
# Instructions:
# 1. Copy this file to .env: cp .env.example .env
# 2. Update the values below with your deployment configuration.
# =============================================================================

# Public-facing domain name for routing (e.g., rbat.example.com)
DOMAIN=localhost

# Email address used for Let's Encrypt TLS registration
ACME_EMAIL=admin@example.com

# Minio Object Storage Root User Credentials
MINIO_ROOT_USER=admin_user
MINIO_ROOT_PASSWORD=super_secure_password_change_me

# PostgreSQL connection string
DATABASE_URL=postgres://username:password@localhost:5432/my_database

# Webhook secret key used for signing/verifying payloads
WEBHOOK_SECRET=whsec_C2FVsBQIhrscChlQIMV+b5sSYspob7oD

# Webhook destination URL (where the server dispatches completed analysis reports)
# For Docker environment: http://rbat-client:3000/api/webhook
# For local development: http://localhost:3000/api/webhook
WEBHOOK_TARGET_URL=http://rbat-client:3000/api/webhook

# gRPC server connection endpoint for the client to stream binary uploads
# For Docker environment: rbat-server:8080
# For local development: localhost:8080
GRPC_SERVER_URL=rbat-server:8080

# Webhook receiver endpoint on the server to trigger static analysis
# For Docker environment: http://rbat-server:8080/webhooks
# For local development: http://localhost:8080/webhooks
WEBHOOK_RECEIVER_URL=http://rbat-server:8080/webhooks

# Google Gemini API Key for streaming AI security insight cards
# Obtain a key from Google AI Studio: https://aistudio.google.com/
GEMINI_API_KEY=

# MinIO Object Storage Endpoint URL
# For Docker environment: http://minio:9000
# For local development: http://localhost:9000
MINIO_ENDPOINT=http://localhost:9000

# Runtime environment mode for the server ("development" or "production")
# Enforces production-grade configuration rules (e.g. required secrets check)
RUN_MODE=development

# Node.js environment mode for the client ("development" or "production")
NODE_ENV=development

# Redis connection URL for streaming UI events
# For Docker environment: redis://redis:6379
# For local development: redis://localhost:6379
REDIS_URL=redis://localhost:6379
